PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai_quiz_generator?retryWrites=true&w=majority
JWT_SECRET=your_strong_random_secret_here

# AI Provider Settings (gemini | openai | groq)
AI_PROVIDER=gemini

# API Keys for AI providers (at least one required)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Allowed frontend origin(s), comma-separated
CLIENT_URL=https://your-app.vercel.app
